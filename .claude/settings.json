{
  "version": "3.1.0",
  "ssot": {
    "enabled": true,
    "strict_mode": true,
    "auto_rebuild": true,
    "duplicate_check": "strict",
    "context_path": ".context",
    "framework_path": ".framework"
  },
  "feedback": {
    "enabled": true,
    "collect_patterns": true,
    "auto_retrospective": true,
    "pattern_threshold": 3
  },
  "hooks": {
    "pre-write": [
      ".claude/hooks/powerbi-quality-check.md",
      ".claude/hooks/documentation-validator.md"
    ],
    "pre-bash": [
      ".claude/hooks/phase-gate-check.md"
    ],
    "pre-commit": [
      ".claude/hooks/commit-quality-check.md",
      ".claude/hooks/file-governance-check.md"
    ],
    "post-phase": [
      ".claude/hooks/retrospectiva-trigger.md"
    ],
    "post-write": [
      ".claude/hooks/ssot-validator.md"
    ]
  },
  "permissions": {
    "allowlist": {
      "bash": [
        "git status",
        "git diff",
        "git log",
        "git add",
        "git commit",
        "git push",
        "git pull",
        "git checkout",
        "git branch",
        "ls",
        "mkdir",
        "cat"
      ],
      "file": {
        "read": true,
        "write": true,
        "edit": true
      }
    }
  },
  "skills": [
    ".claude/skills/vision",
    ".claude/skills/validate",
    ".claude/skills/build",
    ".claude/skills/transcrever-reuniao",
    ".claude/skills/status",
    ".claude/skills/retrospectiva",
    ".claude/skills/revisar-modelo",
    ".claude/skills/inicializar-pbip",
    ".claude/skills/criar-medida",
    ".claude/skills/criar-relacionamento",
    ".claude/skills/criar-visual",
    ".claude/skills/criar-calculation-group",
    ".claude/skills/otimizar-query",
    ".claude/skills/configurar-rls",
    ".claude/skills/configurar-incremental-refresh",
    ".claude/skills/deploy-pbip",
    ".claude/skills/validar-modelo",
    ".claude/skills/verificar-estrutura",
    ".claude/skills/organizar-arquivos",
    ".claude/skills/limpar-temporarios",
    ".claude/skills/resumir-documento",
    ".claude/skills/auditoria-arquivos",
    ".claude/skills/status-arquivos"
  ],
  "agents": [
    ".claude/agents/orchestrator.md",
    ".claude/agents/vision-discovery.md",
    ".claude/agents/validate-poc.md",
    ".claude/agents/build-implementer-v2.md",
    ".claude/agents/meeting-transcriber.md",
    ".claude/agents/file-governance-agent.md",
    ".claude/agents/pattern-detector.md"
  ],
  "primaryAgent": "orchestrator",
  "governanceAgent": "file-governance-agent",
  "learningAgent": "pattern-detector",
  "mcpServers": {
    "power-bi-modeling": {
      "enabled": true
    }
  },
  "context": {
    "projectHistory": ".context",
    "frameworkPatterns": ".framework/index/patterns.index.md",
    "antiPatterns": ".claude/feedback/anti-patterns",
    "improvements": ".claude/feedback/improvements",
    "decisionsLog": ".context/decisions.log",
    "artifactsLog": ".context/artifacts.log",
    "statusLog": ".context/status.log",
    "changesLog": ".context/changes.log",
    "contextIndex": ".context/index.json"
  },
  "templates": {
    "contextStructure": "templates/.context/.structure/template.md"
  }
}
